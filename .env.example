# ---------- Splunk MCP ----------
# URL of the Splunk MCP server (Splunk's official MCP endpoint, exposed via splunkd).
SPLUNK_MCP_URL=https://localhost:8089/services/mcp/v1

# Splunk authentication token. Create one in Splunk Web:
#   Settings -> Tokens -> New Token
SPLUNK_TOKEN=your-splunk-auth-token-here

# ---------- Anthropic ----------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use for the agent. Current recommended model as of 2026-06.
CLAUDE_MODEL=claude-sonnet-4-6

# ---------- App ----------
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Backend bind host/port (optional — defaults to 127.0.0.1:8000)
# HOST=127.0.0.1
# PORT=8000

# Comma-separated origins allowed by the FastAPI CORS middleware (optional).
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
